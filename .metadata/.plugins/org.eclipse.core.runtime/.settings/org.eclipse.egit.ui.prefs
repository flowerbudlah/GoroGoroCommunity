commit_dialog_history_messages=<?xml version\="1.0" encoding\="UTF-8"?>\r\n<messages>\r\n<message>\uAD00\uB9AC\uC790 \uBAA8\uB4DC\uB85C \uB85C\uADF8\uC778\uC2DC \uAD00\uB9AC\uC790\uC758 \uAD8C\uD55C\uC73C\uB85C \uAC8C\uC2DC\uBB3C\uC5D0 \uB300\uD55C \uC720\uD6A8 \uACBD\uACE0\uC218</message>\r\n<message>\uB85C\uADF8\uC778\uC744 \uD55C \uD68C\uC6D0\uC758 \uB85C\uADF8\uC778 \uC2E4\uC2DC\uAC04 \uAE30\uB85D\uC744 \uAD00\uB9AC\uC790\uB9CC \uBCFC\uC218\uC788\uB3C4\uB85D \uCD94\uAC00</message>\r\n<message>20241221</message>\r\n<message>....</message>\r\n<message>test</message>\r\n<message>secret</message>\r\n<message>\uBE44\uBC00\uBC88\uD638 \uBD84\uC2E4\uC2DC \uC774\uBA54\uC77C\uB85C \uC784\uC2DC \uBE44\uBC00\uBC88\uD638 \uBCF4\uB0B4\uAE30 \uAE30\uB2A5 \uC131\uACF5\!&\#x0A;&\#x0A;Adding the function of sending a email about Temporary Passwords When&\#x0A;forgetting user&apos;s passwords.</message>\r\n</messages>
